<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- Material3 parent required by react-native-bottom-tabs (Android BottomNavigationView).
       Normally applied by the library's Expo config plugin, but this project commits
       native folders and skips prebuild, so it's set here manually.
       Light (not DayNight): the app is light-only (content is #FAFAFA/white and
       app.json sets userInterfaceStyle=light). DayNight followed the system dark
       mode and flipped native surfaces (AlertDialog, pickers) to a dark variant
       whose button text used colorPrimary (#023c69 navy) on a dark-grey surface —
       nearly invisible. Forcing Light keeps every native popup readable regardless
       of the phone's system theme. -->
  <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
    <!-- Fully transparent button (3-button) nav bar: drop the semi-opaque grey
         contrast scrim so the light app content blends behind it edge-to-edge.
         windowLightNavigationBar=true → dark nav icons, readable on our light
         (#FAFAFA/white) content. Kept in sync with app.json androidNavigationBar,
         but this file is what the build uses (native folders committed, prebuild skipped). -->
    <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
    <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
    <item name="colorPrimary">@color/colorPrimary</item>
    <item name="android:statusBarColor">#ffffff</item>
  </style>
  <style name="Theme.App.SplashScreen" parent="AppTheme">
    <item name="android:windowBackground">@drawable/ic_launcher_background</item>
  </style>
</resources>