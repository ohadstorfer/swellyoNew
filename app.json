{
  "expo": {
    "name": "Swellyo",
    "slug": "swellyo",
    "version": "1.3.1",
    "runtimeVersion": "1.3.1",
    "updates": {
      "url": "https://u.expo.dev/c14ee9e6-bad8-43e2-b37a-d196b49f638f"
    },
    "scheme": "swellyo",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#212121"
    },
    "ios": {
      "bundleIdentifier": "com.swellyo.app",
      "appleTeamId": "683UA9HZYT",
      "buildNumber": "41",
      "supportsTablet": false,
      "usesNonExemptEncryption": false,
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:swellyo-invite.netlify.app"
      ],
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.usernotifications.communication": true,
        "com.apple.security.application-groups": [
          "group.com.swellyo.app"
        ]
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Swellyo accesses your photo library so you can select photos and videos for your profile, your surf trips, and to share in chats.",
        "NSCameraUsageDescription": "Swellyo uses your camera so you can take photos and record videos for your profile and to send in chats.",
        "NSMicrophoneUsageDescription": "Swellyo uses your microphone to record voice messages and capture audio for video clips.",
        "NSContactsUsageDescription": "Swellyo accesses your contacts so you can share a contact card in chats.",
        "NSUserActivityTypes": [
          "INSendMessageIntent"
        ]
      },
      "runtimeVersion": "1.3.1"
    },
    "android": {
      "package": "com.swellyo.app",
      "versionCode": 30,
      "userInterfaceStyle": "light",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#212121"
      },
      "edgeToEdgeEnabled": true,
      "androidNavigationBar": {
        "enforceContrast": false,
        "barStyle": "dark-content"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_CONTACTS"
      ],
      "blockedPermissions": [],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "swellyo-invite.netlify.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#FAFAFA"
    },
    "plugins": [
      "expo-web-browser",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Swellyo accesses your photo library so you can select photos and videos for your profile, your surf trips, and to share in chats.",
          "cameraPermission": "Swellyo uses your camera so you can take photos and record videos for your profile and to send in chats.",
          "preferNativeMediaPicker": true,
          "androidCropToolbarColor": "#ffffff",
          "androidCropToolbarWidgetColor": "#000000"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Swellyo uses your camera so you can take photos and record videos for your profile and to send in chats.",
          "microphonePermission": "Swellyo uses your microphone to record voice messages and capture audio for video clips.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Swellyo accesses your photo library so you can select photos and videos for your profile, your surf trips, and to share in chats."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.731913999896-l8kdj4dfd9841q7ed7kkqoqliq98t2oa"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#05BCD3"
        }
      ],
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "swellyo"
        }
      ],
      "@bacons/apple-targets",
      "react-native-bottom-tabs",
      [
        "expo-share-intent",
        {
          "disableIOS": true,
          "androidIntentFilters": ["text/*", "image/*", "video/*"],
          "androidMultiIntentFilters": ["image/*", "video/*"]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c14ee9e6-bad8-43e2-b37a-d196b49f638f"
      }
    }
  }
}
