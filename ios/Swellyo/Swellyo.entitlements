<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>aps-environment</key>
    <string>production</string>
    <key>com.apple.developer.applesignin</key>
    <array>
      <string>Default</string>
    </array>
    <key>com.apple.developer.associated-domains</key>
    <array>
      <string>applinks:swellyo-invite.netlify.app</string>
    </array>
    <key>com.apple.developer.usernotifications.communication</key>
    <true/>
    <!-- Shared with the SwellyoShare extension: the App Group container carries
         the recents cache + staged payloads, and iOS automatically treats app
         groups as keychain access groups, which is how sessionBridge.ts hands
         the extension a short-lived Supabase access token. -->
    <key>com.apple.security.application-groups</key>
    <array>
      <string>group.com.swellyo.app</string>
    </array>
  </dict>
</plist>