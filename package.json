{
  "name": "swellyo",
  "version": "1.0.7",
  "main": "index.ts",
  "scripts": {
    "postinstall": "patch-package",
    "test": "jest",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web && cp public/swelly_chat.html dist/ && node update-bundle.js && node create-amplify-files.js",
    "build:netlify": "npm run build:netlify:pre && expo export --platform web && npm run build:netlify:post",
    "build:netlify:pre": "([ -f next.config.js ] && mv next.config.js next.config.js.bak || true) && ([ -d pages ] && mv pages pages.bak || true)",
    "build:netlify:post": "node update-bundle.js && node create-netlify-redirects.js",
    "compress-videos": "node scripts/compress-videos.js",
    "backfill-posthog": "node scripts/backfillPostHogUsers.js",
    "convert-surf-videos": "node scripts/convert-surf-videos-to-h264.js"
  },
