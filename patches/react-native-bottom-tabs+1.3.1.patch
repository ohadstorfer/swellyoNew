     if let icon {
@@ -14,11 +21,45 @@ struct TabItem: View {
       Image(uiImage: icon)
 #endif
     } else if let sfSymbol, !sfSymbol.isEmpty {
-      Image(systemName: sfSymbol)
-        .noneSymbolVariant()
+      // Swellyo patch: outline when unselected, `.fill` when selected — restores
+      // the app's outline-inactive look while adding fill-on-select. Upstream
+      // called `.noneSymbolVariant()` which forced `.none` on BOTH states (no
+      // selected fill); SwiftUI's default fills BOTH. Driving the variant off
+      // `focused` gives the WhatsApp-style outline→fill, and on iOS 17+ the
+      // content transition animates it as SF Symbols "Magic Replace".
+      symbolImage(sfSymbol)
+        .environment(\.symbolVariants, focused ? .fill : .none)
+        .modifier(SymbolMorphTransition())
     }
     if labeled != false {
       Text(title ?? "")
     }
   }
+
+  // `Image(systemName:)` resolves ONLY system symbols; a custom app-bundled
+  // symbol (asset-catalog Symbol Image Set) must load via `Image(_:)`.
+  @ViewBuilder
+  private func symbolImage(_ name: String) -> some View {
+#if os(macOS)
+    Image(systemName: name)
+#else
+    if UIImage(systemName: name) != nil {
+      Image(systemName: name)
+    } else {
+      Image(name)
+    }
+#endif
+  }
+}
+
+// Animates the outline↔fill variant change as SF Symbols "Magic Replace" where
+// available (iOS 17+). No-op on older OSes — the states still switch correctly.
+private struct SymbolMorphTransition: ViewModifier {
+  func body(content: Content) -> some View {
+    if #available(iOS 17.0, macOS 14.0, tvOS 17.0, visionOS 1.0, *) {
+      content.contentTransition(.symbolEffect(.replace))
+    } else {
+      content
+    }
+  }
 }
