+#endif
 
 struct TabItem: View {
   var title: String?
   var icon: PlatformImage?
   var sfSymbol: String?
   var labeled: Bool?
+  // Swellyo patch: whether THIS tab is the selected one, so we can fill the
+  // symbol only when selected (SwiftUI's TabView otherwise fills every tab
